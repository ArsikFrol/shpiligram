generator client {
    provider     = "prisma-client"
    output       = "../../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

enum ChatType {
    DIALOG
    GROUP
}

enum MemberRole {
    OWNER
    ADMIN
    MEMBER
}

enum MessageType {
    TEXT
    IMAGE
    VIDEO
    AUDIO
    FILE
}

model User {
    id       String @id @default(cuid())
    name     String
    userName String @unique @map("user_name")
    avatar   String
    password String
    email    String @unique
    mobile   String
    birthday String

    chats    ChatMember[]
    messages Message[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("users")
}

model Chat {
    id     String   @id @default(cuid())
    title  String?
    type   ChatType @default(DIALOG)
    avatar String?

    members       ChatMember[]
    messages      Message[]
    lastMessageId String?      @unique @map("last_message_id")
    lastMessage   Message?     @relation("LastMessageInChat", fields: [lastMessageId], references: [id])

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("chats")
}

model ChatMember {
    id       String     @id @default(cuid())
    userId   String     @map("user_id")
    chatId   String     @map("chat_id")
    role     MemberRole @default(MEMBER)
    joinedAt DateTime   @default(now()) @map("joined_at")

    user User @relation(fields: [userId], references: [id])
    chat Chat @relation(fields: [chatId], references: [id])

    @@unique([userId, chatId])
    @@map("chat_members")
}

model Message {
    id       String      @id @default(cuid())
    content  String      @db.Text
    type     MessageType @default(TEXT)
    fileUrl  String?     @map("file_url")
    senderId String      @map("sender_id")
    chatId   String      @map("chat_id")
    sentAt   DateTime    @default(now()) @map("sent_at")

    sender        User  @relation(fields: [senderId], references: [id])
    chat          Chat  @relation(fields: [chatId], references: [id])
    lastMessageIn Chat? @relation("LastMessageInChat")

    @@index([chatId, sentAt])
    @@map("messages")
}
