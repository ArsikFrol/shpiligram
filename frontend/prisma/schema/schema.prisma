generator client {
    provider     = "prisma-client"
    output       = "../../src/generated/prisma"
    moduleFormat = "cjs"
}

datasource db {
    provider = "postgresql"
}

model User {
    id String @id @default(cuid())

    name     String
    userName String @unique @map("user_name")
    avatar   String
    password String
    email    String @unique

    mobile  String
    birhday String

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("Users")
}

model Chat {
    id String @id @default(cuid())

    ownersId String[] @map("owners_id")

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("Chats")
}
