enum UserRole {
    USER
    ADMIN
}

model User {
    userId String @id @default(cuid()) @map("user_id") /* user_1 */

    firstName String   @map("first_name")
    lastName  String   @map("last_name")
    userName  String   @unique @map("user_name")
    lastSeen  DateTime @map("last_seen")
    avatar    String

    isOnline Boolean  @default(false) @map("is_online")
    role     UserRole

    password String?
    email    String? @unique

    mobile   String   @unique /* +1 (555) 333-44-55 */
    birthday DateTime /* November 10 */
    bio      String

    ownerChats          Chat[] @relation("owner_chats")
    chatsAsInterlocutor Chat[] @relation("interlocutor_chats")
    senderGifts         Gift[] @relation("senderGifts")
    recipientGifts      Gift[] @relation("recipientGifts")

    stories      Story[]
    likes        Like[]
    messages     Message[]
    storyVieweds StoryViewed[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("users")
}
